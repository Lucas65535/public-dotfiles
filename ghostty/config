# font-family = "Google Sans Code"
# font-family = TX-02-Data
font-family = "Maple Mono NF CN"
# font-family = "Ioskeley Mono"
font-size = 12.4
font-thicken = true
cursor-style = block
cursor-style-blink = true
adjust-cell-height = 1

macos-option-as-alt = true

# shiftやctrlを押しながらでも改行が入力できるように
keybind = shift+enter=text:\x0d
keybind = ctrl+enter=text:\x0d

# Quake Terminal
keybind = global:cmd+shift+space=toggle_quick_terminal

# タイピング中はカーソルを非表示
mouse-hide-while-typing = true

# titlebarをtab形式に
macos-titlebar-style = hidden

# シェル連携のカーソル制御を無効化
shell-integration-features = no-cursor

# ssh接続先での$TERM対策
term = xterm-256color

# 减少水平边距，节省屏幕空间
window-padding-x = 3
window-padding-y = 2
window-save-state = "always"
# Full opacity makes blur effectively useless, and a light theme benefits from a cleaner backdrop.
background-blur-radius = 0

background-opacity = 1
window-colorspace = "display-p3"
# Follow the macOS appearance setting.
theme = light:claude-light.conf,dark:claude-dark.conf
# theme = light:token-light.conf,dark:token-dark.conf
# theme = token-light.conf
# theme = token-dark.conf
# theme = Glacier.conf
# theme = TokyoNight.conf
# theme = aura.conf
# theme = tokyonight
# theme = monokai-pro.conf
# theme = Breadog
# Rosé Pine Dawn https://rosepinetheme.com/palette/ingredients
# background = faf4ed
# background = #0d0d0d
# Keep theme-defined selection colors visible after copying.
selection-clear-on-copy = false

keybind = ¥=text:\\
